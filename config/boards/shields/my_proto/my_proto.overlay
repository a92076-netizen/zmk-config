#include <dt-bindings/zmk/matrix_transform.h>
#include <dt-bindings/gpio/gpio.h>

/ {
    chosen {
        zmk,kscan = &kscan0;
        /* ディスプレイの有効化（ここを修正しました） */
        zephyr,display = &oled;
        zmk,battery = &vbatt;
    };
};

&xiao_i2c {
    status = "okay";
    clock-frequency = <100000>;

    /* SSD1306 128x32 (リセットピンあり) の定義を復活させました */
    oled: ssd1306@3c {
        compatible = "solomon,ssd1306fb";
        reg = <0x3c>;
        width = <128>;
        height = <32>;
        display-offset = <0>;
        multiplex-ratio = <31>;
        segment-offset = <0>;
        page-offset = <0>;
        prechargep = <0x22>;
        
        /* リセットピンを D6 に接続している設定 */
        reset-gpios = <&xiao_d 6 GPIO_ACTIVE_LOW>;
        
        /* 表示を安定させる標準設定 */
        segment-remap;
        com-invdir;
    };
};